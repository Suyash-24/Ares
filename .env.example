# Discord Bot Configuration
DISCORD_TOKEN=your_discord_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_PREFIX=.
OWNER_IDS=your_user_id_here,another_owner_id

# Database Configuration (PostgreSQL - Primary)
# Leave empty to skip PostgreSQL and use fallback (SQLite or JSON)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kira_bot
DB_USER=postgres
DB_PASSWORD=your_password_here

# Note: The bot will automatically try:
# 1. PostgreSQL (if configured)
# 2. SQLite (as fallback)
# 3. JSON file (as final fallback)
